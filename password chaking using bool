bool isValidPassword (String password){
  if(password.length < 8){
    return false;
  }
  
  bool hasNumber = password.contains(RegExp(r'[0-9]'));
  
  return hasNumber;
}

void main(){
  if(isValidPassword("sdfd1dsfdsdff")==true){
    print("Yes! it'a a valid password...");
    }
    else{
      print("No, it's not a valid password..!");
    }

}
