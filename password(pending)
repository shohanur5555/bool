bool isValiduserName(String username){
  
  final bool hasValiduser = username.contains("admin");
  return hasValiduser;
  
}
bool isValidPassword(String password){
  
  final bool hasValidPass= password.contains("1234");
  return hasValidPass;
}
void main(){
  isValiduserName("admin");
  isValidPassword("1234");
  
  if(isValiduserName == true ){
    if(isValidPassword == true){
      print("You are a valid user");
    }
  }
  else{
    print("You are not a valid user");
  }
  }
  
