bool isValidPassword(String password){
  if(password.length < 8){
    return false;
  }
  
  bool hasNumber = password.contains(RegExp(r'[0-9]'));
  
  return hasNumber;
}
void main(){
  if(isValidPassword("sdfdsf")== true){
    print("Yes, it's a valid password..");
  }
  else{
    print("It's not a valid password");
  }
}
